# AetherOS Environment Configuration Template
# Copy this file to .env and customize for your environment

# General Configuration
AETHEROS_ENV=development
AETHEROS_PORT=8000
AETHEROS_HOST=0.0.0.0
AETHEROS_WORKERS=4
AETHEROS_TIMEOUT=300
AETHEROS_LOG_LEVEL=info

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aetheros
POSTGRES_USER=aetheros
POSTGRES_PASSWORD=aetheros

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Security Configuration
SECRET_KEY=change-this-to-a-strong-random-value
JWT_SECRET=change-this-to-a-strong-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Development Configuration
DEBUG=true
AUTO_RELOAD=true

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=/var/log/aetheros/app.log

# Performance Configuration
WORKER_CONCURRENCY=4
MAX_REQUEST_SIZE=10485760

# External Services
OPEN_AI_API_KEY=
GITHUB_API_KEY=

# Feature Flags
FEATURE_EXPERIMENTAL=false
FEATURE_AUDIT_LOG=true

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60