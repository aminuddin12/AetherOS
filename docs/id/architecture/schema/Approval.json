{
  "$defs": {
    "ApprovalStatus": {
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "title": "ApprovalStatus",
      "type": "string"
    },
    "ResourceReference": {
      "additionalProperties": false,
      "description": "Pointers ke resource lain untuk mencegah deep object graph.\nSangat cocok untuk Event Sourcing dan penyimpanan relasional.",
      "properties": {
        "id": {
          "description": "Unique ID of the referenced resource",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "description": "Type of the resource (e.g., 'Worker', 'Task')",
          "title": "Kind",
          "type": "string"
        },
        "namespace": {
          "default": "default",
          "description": "Resource namespace",
          "title": "Namespace",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human readable name",
          "title": "Name"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Specific version if applicable",
          "title": "Version"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Cached labels for fast filtering",
          "title": "Labels",
          "type": "object"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "ResourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Gatekeeper (Human-in-the-Loop) persetujuan aksi kritis.",
  "properties": {
    "required_role": {
      "description": "Role required to approve",
      "title": "Required Role",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ApprovalStatus",
      "default": "pending"
    },
    "approved_by_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ResourceReference"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Who approved it"
    }
  },
  "required": [
    "required_role"
  ],
  "title": "Approval",
  "type": "object"
}