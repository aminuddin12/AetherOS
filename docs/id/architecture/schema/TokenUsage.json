{
  "$defs": {
    "CostRecord": {
      "additionalProperties": false,
      "description": "Pencatatan biaya finansial dalam sistem.",
      "properties": {
        "currency": {
          "default": "USD",
          "description": "ISO 4217 currency code",
          "title": "Currency",
          "type": "string"
        },
        "amount": {
          "description": "Total cost amount",
          "title": "Amount",
          "type": "number"
        },
        "billable_entity_id": {
          "description": "ID of the workspace or project billed",
          "title": "Billable Entity Id",
          "type": "string"
        }
      },
      "required": [
        "amount",
        "billable_entity_id"
      ],
      "title": "CostRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Konsumsi token LLM dalam satu eksekusi.",
  "properties": {
    "prompt_tokens": {
      "default": 0,
      "description": "Tokens used for input prompt",
      "title": "Prompt Tokens",
      "type": "integer"
    },
    "completion_tokens": {
      "default": 0,
      "description": "Tokens generated by model",
      "title": "Completion Tokens",
      "type": "integer"
    },
    "total_tokens": {
      "default": 0,
      "description": "Total tokens consumed",
      "title": "Total Tokens",
      "type": "integer"
    },
    "estimated_cost": {
      "anyOf": [
        {
          "$ref": "#/$defs/CostRecord"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Estimated financial cost"
    }
  },
  "title": "TokenUsage",
  "type": "object"
}