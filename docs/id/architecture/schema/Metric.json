{
  "$defs": {
    "MetricType": {
      "enum": [
        "counter",
        "gauge",
        "histogram",
        "summary"
      ],
      "title": "MetricType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Definisi (metadata) dari suatu matriks yang akan diukur.",
  "properties": {
    "schema_version": {
      "default": "1.0",
      "description": "Schema version of this contract",
      "title": "Schema Version",
      "type": "string"
    },
    "contract_version": {
      "default": "1.0",
      "description": "Data contract compatibility version",
      "title": "Contract Version",
      "type": "string"
    },
    "api_version": {
      "default": "v1",
      "description": "API route version",
      "title": "Api Version",
      "type": "string"
    },
    "spec_version": {
      "default": "1.0",
      "description": "Specification/Behavioral version",
      "title": "Spec Version",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Generic metadata",
      "title": "Metadata",
      "type": "object"
    },
    "labels": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Identifying labels (e.g., tier: backend)",
      "title": "Labels",
      "type": "object"
    },
    "annotations": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Non-identifying metadata",
      "title": "Annotations",
      "type": "object"
    },
    "tags": {
      "description": "Categorization tags",
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "description": "Plugin specific extensions",
      "title": "Extensions",
      "type": "object"
    },
    "owner": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Resource owner reference",
      "title": "Owner"
    },
    "created_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Who created this resource",
      "title": "Created By"
    },
    "managed_by": {
      "default": "aether-kernel",
      "description": "Controller managing this resource",
      "title": "Managed By",
      "type": "string"
    },
    "id": {
      "description": "Global unique identifier for this entity",
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "namespace": {
      "default": "default",
      "description": "Namespace isolating this entity",
      "title": "Namespace",
      "type": "string"
    },
    "created_at": {
      "description": "Creation timestamp",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Last modification timestamp",
      "title": "Updated At"
    },
    "name": {
      "description": "Name of the metric (e.g., 'http_requests_total')",
      "title": "Name",
      "type": "string"
    },
    "description": {
      "description": "Human readable description",
      "title": "Description",
      "type": "string"
    },
    "metric_type": {
      "$ref": "#/$defs/MetricType",
      "description": "Type of metric"
    },
    "unit": {
      "description": "Unit of measurement (e.g., 'seconds', 'bytes')",
      "title": "Unit",
      "type": "string"
    }
  },
  "required": [
    "name",
    "description",
    "metric_type",
    "unit"
  ],
  "title": "Metric",
  "type": "object"
}