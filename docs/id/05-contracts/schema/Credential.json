{
  "$defs": {
    "CredentialType": {
      "enum": [
        "password",
        "api_key",
        "oauth_token",
        "certificate"
      ],
      "title": "CredentialType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Representasi dari rahasia atau token yang membuktikan identitas.\nHanya mendefinisikan referensi, BUKAN nilai secret plaintext.",
  "properties": {
    "schema_version": {
      "default": "1.0",
      "description": "Schema version of this contract",
      "title": "Schema Version",
      "type": "string"
    },
    "contract_version": {
      "default": "1.0",
      "description": "Data contract compatibility version",
      "title": "Contract Version",
      "type": "string"
    },
    "api_version": {
      "default": "v1",
      "description": "API route version",
      "title": "Api Version",
      "type": "string"
    },
    "spec_version": {
      "default": "1.0",
      "description": "Specification/Behavioral version",
      "title": "Spec Version",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Generic metadata",
      "title": "Metadata",
      "type": "object"
    },
    "labels": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Identifying labels (e.g., tier: backend)",
      "title": "Labels",
      "type": "object"
    },
    "annotations": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Non-identifying metadata",
      "title": "Annotations",
      "type": "object"
    },
    "tags": {
      "description": "Categorization tags",
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "description": "Plugin specific extensions",
      "title": "Extensions",
      "type": "object"
    },
    "owner": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Resource owner reference",
      "title": "Owner"
    },
    "created_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Who created this resource",
      "title": "Created By"
    },
    "managed_by": {
      "default": "aether-kernel",
      "description": "Controller managing this resource",
      "title": "Managed By",
      "type": "string"
    },
    "id": {
      "description": "Global unique identifier for this entity",
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "namespace": {
      "default": "default",
      "description": "Namespace isolating this entity",
      "title": "Namespace",
      "type": "string"
    },
    "created_at": {
      "description": "Creation timestamp",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Last modification timestamp",
      "title": "Updated At"
    },
    "identity_id": {
      "description": "Owner of the credential",
      "title": "Identity Id",
      "type": "string"
    },
    "credential_type": {
      "$ref": "#/$defs/CredentialType",
      "description": "Type of authentication secret"
    },
    "is_active": {
      "default": true,
      "description": "Whether this credential is valid",
      "title": "Is Active",
      "type": "boolean"
    }
  },
  "required": [
    "identity_id",
    "credential_type"
  ],
  "title": "Credential",
  "type": "object"
}