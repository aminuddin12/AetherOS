          "title": "Tasks Completed",
          "type": "integer"
        },
        "is_cleared_for_production": {
          "default": false,
          "description": "Has passed certification",
          "title": "Is Cleared For Production",
          "type": "boolean"
        }
      },
      "title": "WorkerLifecycle",
      "type": "object"
    }
